            tween(body, 0.14, {Position = UDim2.new(0, 0, 0, -8)})
            task.delay(0.12, function()
                if window.Minimized then
                    body.Visible = false
                end
            end)
            tween(main, 0.18, {Size = UDim2.new(main.Size.X.Scale, main.Size.X.Offset, 0, 34)})
        else
            body.Visible = true
            body.Position = UDim2.new(0, 0, 0, -8)
            resizeGrip.Visible = true
            tween(main, 0.18, {Size = window.StoredSize})
            tween(body, 0.16, {Position = UDim2.new(0, 0, 0, 34)})
            task.delay(0.2, function()
                window:ClampToScreen()
            end)
        end
    end


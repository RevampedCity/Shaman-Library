        local dragStart, startPos
        topbar.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                dragging = true
                dragStart = input.Position
                startPos = main.Position
                input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then dragging = false end
                end)
            end
        end)
        UserInputService.InputChanged:Connect(function(input)
            if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                local delta = input.Position - dragStart
                main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            end
        end)
    end

    do
        local resizing = false
        local resizeStart, startSize
        resizeGrip.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                resizing = true
                resizeStart = input.Position
                startSize = main.AbsoluteSize
                input.Changed:Connect(function()
                    if input.UserInputState == Enum.UserInputState.End then
                        resizing = false
                        if not window.Minimized then window.StoredSize = main.Size end
                    end
                end)
            end
        end)
        UserInputService.InputChanged:Connect(function(input)
            if resizing and input.UserInputType == Enum.UserInputType.MouseMovement then
                local delta = input.Position - resizeStart
                local newX = math.clamp(startSize.X + delta.X, window.MinSize.X, window.MaxSize.X)
                local newY = math.clamp(startSize.Y + delta.Y, window.MinSize.Y, window.MaxSize.Y)
                main.Size = UDim2.fromOffset(newX, newY)
                if not window.Minimized then window.StoredSize = main.Size end
            end
        end)
    end

    function window:ApplySearch(query)
        query = string.lower(query or "")
        for _, item in ipairs(window.SearchItems) do
            local visible = query == "" or string.find(string.lower(item.Text), query, 1, true) ~= nil
            item.Object.Visible = visible
        end
    end

    searchBox:GetPropertyChangedSignal("Text"):Connect(function()
        window:ApplySearch(searchBox.Text)
    end)

    function window:Tab(info)
        info = info or {}
        local tab = {}
        tab.Title = info.Text or info.Title or "Tab"

        local tabButton = create("TextButton", {
            Size = UDim2.new(1, 0, 0, 24), BackgroundColor3 = Library.Theme.Surface2, Text = "",
            AutoButtonColor = false, Parent = tabsHolder,
        })
        corner(tabButton, 5)
        stroke(tabButton, Library.Theme.Stroke, 1)
        Library:AddTooltip(tabButton, "Open " .. tab.Title)

        local tabAccent = create("Frame", {
            BackgroundColor3 = Library.Theme.Accent, BackgroundTransparency = 0.35,
            Visible = false, Size = UDim2.new(1, 0, 1, 0), Parent = tabButton,
        })
        corner(tabAccent, 5)

        local tabLabel = create("TextLabel", {
            BackgroundTransparency = 1, Position = UDim2.new(0, 8, 0, 0), Size = UDim2.new(1, -16, 1, 0),
            Text = tab.Title, Font = Enum.Font.GothamBold, TextSize = 10, TextXAlignment = Enum.TextXAlignment.Left,
            TextColor3 = Library.Theme.SubText, Parent = tabButton,
        })

        local page = create("Frame", {Name = tab.Title .. "Page", BackgroundTransparency = 1, Visible = false, Size = UDim2.new(1, 0, 1, 0), Parent = pages})
        local left = create("ScrollingFrame", {Name = "Left", BackgroundTransparency = 1, BorderSizePixel = 0, AutomaticCanvasSize = Enum.AutomaticSize.Y, CanvasSize = UDim2.new(), ScrollBarThickness = 3, Size = UDim2.new(0.5, -5, 1, 0), Parent = page})
        padding(left, 0, 3, 0, 0)
        list(left, Enum.SortOrder.LayoutOrder, 6)
        local right = create("ScrollingFrame", {Name = "Right", BackgroundTransparency = 1, BorderSizePixel = 0, AutomaticCanvasSize = Enum.AutomaticSize.Y, CanvasSize = UDim2.new(), ScrollBarThickness = 3, Position = UDim2.new(0.5, 5, 0, 0), Size = UDim2.new(0.5, -5, 1, 0), Parent = page})
        padding(right, 3, 0, 0, 0)
        list(right, Enum.SortOrder.LayoutOrder, 6)

        function tab:Select()
            for _, other in ipairs(window.Tabs) do
                other.Page.Visible = false
                other.Accent.Visible = false
                tween(other.Button, 0.1, {BackgroundColor3 = Library.Theme.Surface2})
                tween(other.Label, 0.1, {TextColor3 = Library.Theme.SubText})
            end
            page.Visible = true
            tabAccent.Visible = true
            tabAccent.BackgroundColor3 = Library.Theme.Accent
            tween(tabButton, 0.1, {BackgroundColor3 = Color3.fromRGB(34, 34, 34)})
            tween(tabLabel, 0.1, {TextColor3 = Library.Theme.Text})
            window.ActiveTab = tab
            window:ApplySearch(searchBox.Text)
        end

        tabButton.MouseEnter:Connect(function() if window.ActiveTab ~= tab then tween(tabButton, 0.1, {BackgroundColor3 = Color3.fromRGB(32, 32, 32)}) end end)
        tabButton.MouseLeave:Connect(function() if window.ActiveTab ~= tab then tween(tabButton, 0.1, {BackgroundColor3 = Library.Theme.Surface2}) end end)
        tabButton.MouseButton1Click:Connect(function() tab:Select() end)

        function tab:Section(info)
            info = info or {}
            local section = {}
            local side = (info.Side == "Right" and right) or left

            local frame = create("Frame", {BackgroundColor3 = Library.Theme.Surface, BorderSizePixel = 0, Size = UDim2.new(1, 0, 0, 28), ClipsDescendants = true, Parent = side})
            corner(frame, 8)
            stroke(frame, Library.Theme.Stroke, 1)

            local sectionHeader = create("TextButton", {Size = UDim2.new(1, 0, 0, 28), BackgroundTransparency = 1, Text = "", AutoButtonColor = false, Parent = frame})
            Library:AddTooltip(sectionHeader, info.Tooltip or ("Open / close " .. (info.Text or "section")))

            local sectionArrow = create("TextLabel", {BackgroundTransparency = 1, Position = UDim2.new(0, 8, 0, 0), Size = UDim2.new(0, 12, 1, 0), Font = Enum.Font.GothamBold, Text = "v", TextSize = 10, TextXAlignment = Enum.TextXAlignment.Left, TextColor3 = Library.Theme.SubText, Parent = sectionHeader})
            local sectionTitle = create("TextLabel", {BackgroundTransparency = 1, Position = UDim2.new(0, 18, 0, 0), Size = UDim2.new(1, -26, 1, 0), Font = Enum.Font.GothamBold, Text = info.Text or "Section", TextSize = 10, TextXAlignment = Enum.TextXAlignment.Left, TextColor3 = Library.Theme.Text, Parent = sectionHeader})
            local sectionContent = create("Frame", {BackgroundTransparency = 1, Position = UDim2.new(0, 8, 0, 28), Size = UDim2.new(1, -16, 0, 0), AutomaticSize = Enum.AutomaticSize.Y, Parent = frame})
            list(sectionContent, Enum.SortOrder.LayoutOrder, 5)
            padding(sectionContent, 0, 0, 0, 8)

            local sectionOpen = true
            local currentHeight = 28
            local function refreshSection(animated)
                sectionContent.Visible = sectionOpen
                sectionArrow.Text = sectionOpen and "v" or ">"
                local target = sectionOpen and (28 + sectionContent.AbsoluteSize.Y + 4) or 28
                if animated then
                    tween(frame, 0.15, {Size = UDim2.new(1, 0, 0, target)})
                else
                    frame.Size = UDim2.new(1, 0, 0, target)
                end
                currentHeight = target
            end

            sectionHeader.MouseButton1Click:Connect(function()
                sectionOpen = not sectionOpen
                refreshSection(true)
            end)

            if info.Description then
                create("TextLabel", {BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 10), Font = Enum.Font.Gotham, Text = info.Description, TextSize = 8, TextXAlignment = Enum.TextXAlignment.Left, TextColor3 = Library.Theme.SubText, Parent = sectionContent})
            end

            sectionContent:GetPropertyChangedSignal("AbsoluteSize"):Connect(function()
                if sectionOpen then refreshSection(false) end
            end)

            table.insert(window.SearchItems, {Text = info.Text or "Section", Object = frame})

            local function baseRow(height)
                return create("Frame", {BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, height or 22), Parent = sectionContent})
            end

            function section:Label(data)
                data = data or {}
                local row = baseRow(18)
                create("TextLabel", {BackgroundTransparency = 1, Size = UDim2.new(1, 0, 1, 0), Font = Enum.Font.Gotham, Text = data.Text or "Label", TextSize = 9, TextXAlignment = Enum.TextXAlignment.Left, TextColor3 = data.Color or Library.Theme.SubText, Parent = row})
                table.insert(window.SearchItems, {Text = data.Text or "Label", Object = row})
                refreshSection(false)
            end

            function section:Button(data)
                data = data or {}
                local button = create("TextButton", {Size = UDim2.new(1, 0, 0, 22), BackgroundColor3 = Library.Theme.Surface2, Text = data.Text or "Button", Font = Enum.Font.GothamBold, TextSize = 9, TextColor3 = Library.Theme.Text, AutoButtonColor = false, Parent = sectionContent})
                corner(button, 5)
                stroke(button, Library.Theme.Stroke, 1)
                Library:AddTooltip(button, data.Tooltip)
                button.MouseEnter:Connect(function() tween(button, 0.1, {BackgroundColor3 = Library.Theme.Accent}) end)
                button.MouseLeave:Connect(function() tween(button, 0.1, {BackgroundColor3 = Library.Theme.Surface2}) end)
                button.MouseButton1Click:Connect(function() if data.Callback then task.spawn(data.Callback) end end)
                table.insert(window.SearchItems, {Text = data.Text or "Button", Object = button})
                refreshSection(false)
                return button
            end

            function section:Toggle(data)
                data = data or {}
                local flag = data.Flag
                local state = data.Default == true
                if flag and Library.Flags[flag] == nil then Library.Flags[flag] = state else if flag then state = Library.Flags[flag] end end

                local row = baseRow(22)
                create("TextLabel", {BackgroundTransparency = 1, Size = UDim2.new(1, -34, 1, 0), Font = Enum.Font.GothamBold, Text = data.Text or "Toggle", TextSize = 9, TextXAlignment = Enum.TextXAlignment.Left, TextColor3 = Library.Theme.Text, Parent = row})
                local toggleBack = create("Frame", {AnchorPoint = Vector2.new(1, 0.5), Position = UDim2.new(1, 0, 0.5, 0), Size = UDim2.fromOffset(28, 14), BackgroundColor3 = state and Library.Theme.Accent or Color3.fromRGB(40, 40, 40), Parent = row})
                corner(toggleBack, 999)
                local knob = create("Frame", {Position = state and UDim2.new(1, -12, 0.5, -5) or UDim2.new(0, 2, 0.5, -5), Size = UDim2.fromOffset(10, 10), BackgroundColor3 = Color3.fromRGB(230, 230, 230), Parent = toggleBack})
                corner(knob, 999)

                local control = {}
                function control:Set(value, silent)
                    state = value == true
                    if flag then Library.Flags[flag] = state end
                    toggleBack.BackgroundColor3 = state and Library.Theme.Accent or Color3.fromRGB(40, 40, 40)
                    knob.Position = state and UDim2.new(1, -12, 0.5, -5) or UDim2.new(0, 2, 0.5, -5)
                    if not silent and data.Callback then task.spawn(function() data.Callback(state) end) end
                end
                Library:RegisterFlag(flag, control)
                Library:AddTooltip(row, data.Tooltip)
                local button = create("TextButton", {BackgroundTransparency = 1, Size = UDim2.new(1, 0, 1, 0), Text = "", Parent = row})
                button.MouseButton1Click:Connect(function() control:Set(not state, false) end)
                table.insert(window.SearchItems, {Text = data.Text or "Toggle", Object = row})
                refreshSection(false)
                return control
            end

            function section:Input(data)
                data = data or {}
                local flag = data.Flag
                local starting = Library.Flags[flag] ~= nil and tostring(Library.Flags[flag]) or (data.Default or "")
                local box = create("TextBox", {Size = UDim2.new(1, 0, 0, 22), BackgroundColor3 = Library.Theme.Surface2, ClearTextOnFocus = false, PlaceholderText = data.Placeholder or "Type here...", Text = starting, Font = Enum.Font.Gotham, TextSize = 9, TextColor3 = Library.Theme.Text, PlaceholderColor3 = Library.Theme.SubText, Parent = sectionContent})
                corner(box, 5)
                stroke(box, Library.Theme.Stroke, 1)
                padding(box, 8, 8, 0, 0)
                if flag then Library.Flags[flag] = box.Text end
                local control = {}
                function control:Set(value, silent)
                    box.Text = tostring(value or "")
                    if flag then Library.Flags[flag] = box.Text end
                    if not silent and data.Callback then task.spawn(function() data.Callback(box.Text) end) end
                end
                Library:RegisterFlag(flag, control)
                Library:AddTooltip(box, data.Tooltip)
                box.FocusLost:Connect(function()
                    if flag then Library.Flags[flag] = box.Text end
                    if data.Callback then task.spawn(function() data.Callback(box.Text) end) end
                end)
                table.insert(window.SearchItems, {Text = data.Placeholder or data.Text or "Input", Object = box})
                refreshSection(false)
                return control
            end

            function section:Slider(data)
                data = data or {}
                local minimum = data.Minimum or 0
                local maximum = data.Maximum or 100
                local starting = Library.Flags[data.Flag] ~= nil and tonumber(Library.Flags[data.Flag]) or (data.Default or minimum)
                local value = math.clamp(starting, minimum, maximum)
                local flag = data.Flag
                if flag then Library.Flags[flag] = value end

                local holder = create("Frame", {Size = UDim2.new(1, 0, 0, 32), BackgroundTransparency = 1, Parent = sectionContent})
                create("TextLabel", {BackgroundTransparency = 1, Size = UDim2.new(0.7, 0, 0, 10), Font = Enum.Font.GothamBold, Text = data.Text or "Slider", TextSize = 9, TextXAlignment = Enum.TextXAlignment.Left, TextColor3 = Library.Theme.Text, Parent = holder})
                local valueLabel = create("TextLabel", {BackgroundTransparency = 1, Position = UDim2.new(0.7, 0, 0, 0), Size = UDim2.new(0.3, 0, 0, 10), Font = Enum.Font.Gotham, Text = tostring(value) .. (data.Postfix or ""), TextSize = 8, TextXAlignment = Enum.TextXAlignment.Right, TextColor3 = Library.Theme.SubText, Parent = holder})
                local bar = create("Frame", {Position = UDim2.new(0, 0, 0, 16), Size = UDim2.new(1, 0, 0, 5), BackgroundColor3 = Color3.fromRGB(40, 40, 40), BorderSizePixel = 0, Parent = holder})
                corner(bar, 999)
                local fill = create("Frame", {Size = UDim2.new((value - minimum) / (maximum - minimum), 0, 1, 0), BackgroundColor3 = Library.Theme.Accent, BorderSizePixel = 0, Parent = bar})
                corner(fill, 999)
                local dragging = false
                local control = {}
                function control:Set(newValue, silent)
                    value = math.clamp(tonumber(newValue) or minimum, minimum, maximum)
                    local percent = (value - minimum) / (maximum - minimum)
                    fill.Size = UDim2.new(percent, 0, 1, 0)
                    valueLabel.Text = tostring(value) .. (data.Postfix or "")
                    if flag then Library.Flags[flag] = value end
                    if not silent and data.Callback then task.spawn(function() data.Callback(value) end) end
                end
                Library:RegisterFlag(flag, control)
                Library:AddTooltip(holder, data.Tooltip)
                local function setFromX(x)
                    local percent = math.clamp((x - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
                    control:Set(math.floor(minimum + ((maximum - minimum) * percent)), false)
                end
                local button = create("TextButton", {BackgroundTransparency = 1, Size = UDim2.new(1, 0, 1, 0), Text = "", Parent = holder})
                button.MouseButton1Down:Connect(function() dragging = true setFromX(Mouse.X) end)
                UserInputService.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
                UserInputService.InputChanged:Connect(function(input) if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then setFromX(Mouse.X) end end)
                table.insert(window.SearchItems, {Text = data.Text or "Slider", Object = holder})
                refreshSection(false)
                return control
            end

            function section:Keybind(data)
                data = data or {}
                local flag = data.Flag
                local current = Library.Flags[flag] and Enum.KeyCode[Library.Flags[flag]] or data.Default or Enum.KeyCode.F
                local listening = false
                if flag then Library.Flags[flag] = current.Name end
                local row = baseRow(22)
                create("TextLabel", {BackgroundTransparency = 1, Size = UDim2.new(0.62, 0, 1, 0), Font = Enum.Font.GothamBold, Text = data.Text or "Keybind", TextSize = 9, TextXAlignment = Enum.TextXAlignment.Left, TextColor3 = Library.Theme.Text, Parent = row})
                local button = create("TextButton", {AnchorPoint = Vector2.new(1, 0.5), Position = UDim2.new(1, 0, 0.5, 0), Size = UDim2.fromOffset(68, 20), BackgroundColor3 = Library.Theme.Surface2, Text = current.Name, Font = Enum.Font.GothamBold, TextSize = 8, TextColor3 = Library.Theme.Text, AutoButtonColor = false, Parent = row})
                corner(button, 5)
                stroke(button, Library.Theme.Stroke, 1)
                local control = {}
                function control:Set(value, silent)
                    if typeof(value) == "EnumItem" then current = value elseif Enum.KeyCode[tostring(value)] then current = Enum.KeyCode[tostring(value)] end
                    button.Text = current.Name
                    if flag then Library.Flags[flag] = current.Name end
                    if not silent and data.Callback then end
                end
                Library:RegisterFlag(flag, control)
                Library:AddTooltip(row, data.Tooltip)
                button.MouseButton1Click:Connect(function()
                    if listening then return end
                    listening = true
                    button.Text = "..."
                    local capture
                    capture = UserInputService.InputBegan:Connect(function(input, gp)
                        if gp then return end
                        if input.UserInputType == Enum.UserInputType.Keyboard and not Library.Blacklist[input.KeyCode] then
                            control:Set(input.KeyCode, true)
                            listening = false
                            capture:Disconnect()
                        end
                    end)
                end)
                UserInputService.InputBegan:Connect(function(input, gp)
                    if gp or listening then return end
                    if input.KeyCode == current and data.Callback then task.spawn(data.Callback) end
                end)
                table.insert(window.SearchItems, {Text = data.Text or "Keybind", Object = row})
                refreshSection(false)
                return control
            end

            refreshSection(false)
            return section
        end

        tab.Button = tabButton
        tab.Label = tabLabel
        tab.Accent = tabAccent
        tab.Page = page
        table.insert(window.Tabs, tab)
        if not window.ActiveTab then tab:Select() end
        return tab
    end

    window.Gui = gui
    window.Main = main
    window.Body = body
    Library.CurrentWindow = window
    table.insert(Library.Windows, window)

    if not next(Library.Connections) then
        Library:BindGlobalToggle()
    end

    window:ApplyTheme()
    return window
end

-- Example usage
local Window = Library:Window({Title = "Shaman"})

local MainTab = Window:Tab({Text = "Main"})
local VisualTab = Window:Tab({Text = "Visuals"})

local Combat = MainTab:Section({Text = "Combat", Side = "Left", Description = "Core combat options", Tooltip = "Main combat section"})
Combat:Toggle({Text = "Enable Aura", Flag = "aura", Default = false, Tooltip = "Master aura toggle", Callback = function(v) print("Aura:", v) end})
Combat:Slider({Text = "Range", Flag = "range", Minimum = 1, Maximum = 30, Default = 12, Postfix = "m", Tooltip = "Aura distance", Callback = function(v) print("Range:", v) end})
Combat:Keybind({Text = "Panic Key", Flag = "panic_bind", Default = Enum.KeyCode.P, Tooltip = "Emergency hide bind", Callback = function() Window:SetOpen(false) end})
Combat:Button({Text = "Save Current Config", Tooltip = "Write current options to disk", Callback = function() Library:SaveConfig() end})

local Misc = MainTab:Section({Text = "Misc", Side = "Right", Description = "Compact utility controls"})
Misc:Input({Placeholder = "Type here...", Flag = "input_demo", Tooltip = "Saved text option", Callback = function(v) print("Input:", v) end})
Misc:Label({Text = "Saved options now restore the actual UI controls too."})

local Theme = VisualTab:Section({Text = "Theme", Side = "Left", Description = "Monochrome styling"})
Theme:Button({Text = "Load Config", Tooltip = "Load config from file", Callback = function() Library:LoadConfig() end})
Theme:Button({Text = "Open Settings", Tooltip = "Open settings panel", Callback = function()
    local panel = Window.Main:FindFirstChild("SettingsPanel")
    if panel then panel.Visible = not panel.Visible end
end})

return Library

                TextXAlignment = Enum.TextXAlignment.Left,
                TextColor3 = Library.Theme.SubText,
                Parent = sectionHeader,
            })

            local sectionTitle = create("TextLabel", {
                BackgroundTransparency = 1,
                Position = UDim2.new(0, 18, 0, 0),
                Size = UDim2.new(1, -26, 1, 0),
                Font = Enum.Font.GothamBold,
                Text = info.Text or "Section",
                TextSize = 10,
                TextXAlignment = Enum.TextXAlignment.Left,
                TextColor3 = Library.Theme.Text,
                Parent = sectionHeader,
            })

            local sectionContent = create("Frame", {
                BackgroundTransparency = 1,
                Position = UDim2.new(0, 8, 0, 28),
                Size = UDim2.new(1, -16, 0, 0),
                AutomaticSize = Enum.AutomaticSize.Y,
                Parent = frame,
            })
            list(sectionContent, Enum.SortOrder.LayoutOrder, 5)
            padding(sectionContent, 0, 0, 0, 8)

            local sectionOpen = true
            local function refreshSection()
                sectionContent.Visible = sectionOpen
                sectionArrow.Text = sectionOpen and "v" or ">"
                frame.Size = UDim2.new(1, 0, 0, sectionOpen and (28 + sectionContent.AbsoluteSize.Y + 4) or 28)
            end

            sectionHeader.MouseButton1Click:Connect(function()
                sectionOpen = not sectionOpen
                refreshSection()
            end)

            if info.Description then
                create("TextLabel", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 10),
                    Font = Enum.Font.Gotham,
                    Text = info.Description,
                    TextSize = 8,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    TextColor3 = Library.Theme.SubText,
                    Parent = sectionContent,
                })
            end

            sectionContent:GetPropertyChangedSignal("AbsoluteSize"):Connect(function()
                refreshSection()
            end)

            local function baseRow(height)
                return create("Frame", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, height or 22),
                    Parent = sectionContent,
                })
            end

            function section:Label(data)
                data = data or {}
                local row = baseRow(18)
                create("TextLabel", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 1, 0),
                    Font = Enum.Font.Gotham,
                    Text = data.Text or "Label",
                    TextSize = 9,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    TextColor3 = data.Color or Library.Theme.SubText,
                    Parent = row,
                })
                refreshSection()
            end

            function section:Button(data)
                data = data or {}
                local button = create("TextButton", {
                    Size = UDim2.new(1, 0, 0, 22),
                    BackgroundColor3 = Library.Theme.Surface2,
                    Text = data.Text or "Button",
                    Font = Enum.Font.GothamBold,
                    TextSize = 9,
                    TextColor3 = Library.Theme.Text,
                    AutoButtonColor = false,
                    Parent = sectionContent,
                })
                corner(button, 5)
                stroke(button, Library.Theme.Stroke, 1)
                button.MouseEnter:Connect(function()
                    tween(button, 0.1, {BackgroundColor3 = Library.Theme.Accent})
                end)
                button.MouseLeave:Connect(function()
                    tween(button, 0.1, {BackgroundColor3 = Library.Theme.Surface2})
                end)
                button.MouseButton1Click:Connect(function()
                    if data.Callback then
                        task.spawn(data.Callback)
                    end
                end)
                refreshSection()
                return button
            end

            function section:Toggle(data)
                data = data or {}
                local flag = data.Flag
                local state = data.Default == true
                if flag then Library.Flags[flag] = state end

                local row = baseRow(22)
                create("TextLabel", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, -34, 1, 0),
                    Font = Enum.Font.GothamBold,
                    Text = data.Text or "Toggle",
                    TextSize = 9,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    TextColor3 = Library.Theme.Text,
                    Parent = row,
                })

                local toggleBack = create("Frame", {
                    AnchorPoint = Vector2.new(1, 0.5),
                    Position = UDim2.new(1, 0, 0.5, 0),
                    Size = UDim2.fromOffset(28, 14),
                    BackgroundColor3 = state and Library.Theme.Accent or Color3.fromRGB(40, 40, 40),
                    Parent = row,
                })
                corner(toggleBack, 999)

                local knob = create("Frame", {
                    Position = state and UDim2.new(1, -12, 0.5, -5) or UDim2.new(0, 2, 0.5, -5),
                    Size = UDim2.fromOffset(10, 10),
                    BackgroundColor3 = Color3.fromRGB(230, 230, 230),
                    Parent = toggleBack,
                })
                corner(knob, 999)

                local function set(value)
                    state = value
                    if flag then Library.Flags[flag] = state end
                    tween(toggleBack, 0.1, {BackgroundColor3 = state and Library.Theme.Accent or Color3.fromRGB(40, 40, 40)})
                    tween(knob, 0.1, {Position = state and UDim2.new(1, -12, 0.5, -5) or UDim2.new(0, 2, 0.5, -5)})
                    if data.Callback then
                        task.spawn(function()
                            data.Callback(state)
                        end)
                    end
                end

                local button = create("TextButton", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 1, 0),
                    Text = "",
                    Parent = row,
                })
                button.MouseButton1Click:Connect(function()
                    set(not state)
                end)

                refreshSection()
                return {Set = set}
            end

            function section:Input(data)
                data = data or {}
                local flag = data.Flag
                local box = create("TextBox", {
                    Size = UDim2.new(1, 0, 0, 22),
                    BackgroundColor3 = Library.Theme.Surface2,
                    ClearTextOnFocus = false,
                    PlaceholderText = data.Placeholder or "Type here...",
                    Text = data.Default or "",
                    Font = Enum.Font.Gotham,
                    TextSize = 9,
                    TextColor3 = Library.Theme.Text,
                    PlaceholderColor3 = Library.Theme.SubText,
                    Parent = sectionContent,
                })
                corner(box, 5)
                stroke(box, Library.Theme.Stroke, 1)
                padding(box, 8, 8, 0, 0)
                if flag then Library.Flags[flag] = box.Text end
                box.FocusLost:Connect(function()
                    if flag then Library.Flags[flag] = box.Text end
                    if data.Callback then
                        task.spawn(function()
                            data.Callback(box.Text)
                        end)
                    end
                end)
                refreshSection()
                return box
            end

            function section:Slider(data)
                data = data or {}
                local minimum = data.Minimum or 0
                local maximum = data.Maximum or 100
                local value = math.clamp(data.Default or minimum, minimum, maximum)
                local flag = data.Flag
                if flag then Library.Flags[flag] = value end

                local holder = create("Frame", {
                    Size = UDim2.new(1, 0, 0, 32),
                    BackgroundTransparency = 1,
                    Parent = sectionContent,
                })

                create("TextLabel", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(0.7, 0, 0, 10),
                    Font = Enum.Font.GothamBold,
                    Text = data.Text or "Slider",
                    TextSize = 9,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    TextColor3 = Library.Theme.Text,
                    Parent = holder,
                })

                local valueLabel = create("TextLabel", {
                    BackgroundTransparency = 1,
                    Position = UDim2.new(0.7, 0, 0, 0),
                    Size = UDim2.new(0.3, 0, 0, 10),
                    Font = Enum.Font.Gotham,
                    Text = tostring(value) .. (data.Postfix or ""),
                    TextSize = 8,
                    TextXAlignment = Enum.TextXAlignment.Right,
                    TextColor3 = Library.Theme.SubText,
                    Parent = holder,
                })

                local bar = create("Frame", {
                    Position = UDim2.new(0, 0, 0, 16),
                    Size = UDim2.new(1, 0, 0, 5),
                    BackgroundColor3 = Color3.fromRGB(40, 40, 40),
                    BorderSizePixel = 0,
                    Parent = holder,
                })
                corner(bar, 999)

                local fill = create("Frame", {
                    Size = UDim2.new((value - minimum) / (maximum - minimum), 0, 1, 0),
                    BackgroundColor3 = Library.Theme.Accent,
                    BorderSizePixel = 0,
                    Parent = bar,
                })
                corner(fill, 999)

                local dragging = false
                local function setFromX(x)
                    local percent = math.clamp((x - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
                    value = math.floor(minimum + ((maximum - minimum) * percent))
                    fill.Size = UDim2.new(percent, 0, 1, 0)
                    valueLabel.Text = tostring(value) .. (data.Postfix or "")
                    if flag then Library.Flags[flag] = value end
                    if data.Callback then
                        task.spawn(function()
                            data.Callback(value)
                        end)
                    end
                end

                local button = create("TextButton", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 1, 0),
                    Text = "",
                    Parent = holder,
                })

                button.MouseButton1Down:Connect(function()
                    dragging = true
                    setFromX(Mouse.X)
                end)

                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        dragging = false
                    end
                end)

                UserInputService.InputChanged:Connect(function(input)
                    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                        setFromX(Mouse.X)
                    end
                end)

                refreshSection()
            end

            function section:Keybind(data)
                data = data or {}
                local flag = data.Flag
                local current = data.Default or Enum.KeyCode.F
                local listening = false
                if flag then Library.Flags[flag] = current.Name end

                local row = baseRow(22)
                create("TextLabel", {
                    BackgroundTransparency = 1,
                    Size = UDim2.new(0.62, 0, 1, 0),
                    Font = Enum.Font.GothamBold,
                    Text = data.Text or "Keybind",
                    TextSize = 9,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    TextColor3 = Library.Theme.Text,
                    Parent = row,
                })

                local button = create("TextButton", {
                    AnchorPoint = Vector2.new(1, 0.5),
                    Position = UDim2.new(1, 0, 0.5, 0),
                    Size = UDim2.fromOffset(68, 20),
                    BackgroundColor3 = Library.Theme.Surface2,
                    Text = current.Name,
                    Font = Enum.Font.GothamBold,
                    TextSize = 8,
                    TextColor3 = Library.Theme.Text,
                    AutoButtonColor = false,
                    Parent = row,
                })
                corner(button, 5)
                stroke(button, Library.Theme.Stroke, 1)

                button.MouseButton1Click:Connect(function()
                    if listening then return end
                    listening = true
                    button.Text = "..."
                    local capture
                    capture = UserInputService.InputBegan:Connect(function(input, gp)
                        if gp then return end
                        if input.UserInputType == Enum.UserInputType.Keyboard and not Library.Blacklist[input.KeyCode] then
                            current = input.KeyCode
                            if flag then Library.Flags[flag] = current.Name end
                            button.Text = current.Name
                            listening = false
                            capture:Disconnect()
                        end
                    end)
                end)

                UserInputService.InputBegan:Connect(function(input, gp)
                    if gp or listening then return end
                    if input.KeyCode == current and data.Callback then
                        task.spawn(data.Callback)
                    end
                end)

                refreshSection()
            end

            refreshSection()
            return section
        end

        tab.Button = tabButton
        tab.Label = tabLabel
        tab.Accent = tabAccent
        tab.Page = page
        table.insert(window.Tabs, tab)

        if not window.ActiveTab then
            tab:Select()
        end

        return tab
    end

    window.Gui = gui
    window.Main = main
    window.Body = body
    Library.CurrentWindow = window
    table.insert(Library.Windows, window)

    if not next(Library.Connections) then
        Library:BindGlobalToggle()
    end

    window:ApplyTheme()

    return window
end

-- Example usage
local Window = Library:Window({Title = "Shaman"})

local MainTab = Window:Tab({Text = "Main"})
local VisualTab = Window:Tab({Text = "Visuals"})

local Combat = MainTab:Section({Text = "Combat", Side = "Left", Description = "Core combat options"})
Combat:Toggle({Text = "Enable Aura", Flag = "aura", Default = false, Callback = function(v) print("Aura:", v) end})
Combat:Slider({Text = "Range", Flag = "range", Minimum = 1, Maximum = 30, Default = 12, Postfix = "m", Callback = function(v) print("Range:", v) end})
Combat:Keybind({Text = "Panic Key", Default = Enum.KeyCode.P, Callback = function() Window:SetOpen(false) end})
Combat:Button({Text = "Save Current Config", Callback = function() Library:SaveConfig() end})

local Misc = MainTab:Section({Text = "Misc", Side = "Right", Description = "Compact utility controls"})
Misc:Input({Placeholder = "Type here...", Flag = "input_demo", Callback = function(v) print("Input:", v) end})
Misc:Label({Text = "Compact stealth styling with collapsible sections."})

local Theme = VisualTab:Section({Text = "Theme", Side = "Left", Description = "Monochrome styling"})
Theme:Button({Text = "Load Config", Callback = function() Library:LoadConfig() end})
Theme:Button({Text = "Open Settings", Callback = function()
    local panel = Window.Main:FindFirstChild("SettingsPanel")
    if panel then panel.Visible = not panel.Visible end
end})

return Library

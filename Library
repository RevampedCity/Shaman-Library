local function deepCopy(tbl)
    local new = {}
    for k, v in pairs(tbl) do
        new[k] = typeof(v) == "table" and deepCopy(v) or v
    end
    return new
end

function Library:GetConfigPath(name)
    return string.format("%s/%s.json", self.ConfigFolder, name or self.ConfigName)
end

function Library:SerializeTheme()
    local data = {}
    for k, v in pairs(self.Theme) do
        if typeof(v) == "Color3" then
            data[k] = {v.R, v.G, v.B}
        end
    end
    return data
end

function Library:ApplySerializedTheme(theme)
    if not theme then return end
    for k, v in pairs(theme) do
        if type(v) == "table" and #v == 3 then
            self.Theme[k] = Color3.new(v[1], v[2], v[3])
        end
    end
end

function Library:SaveConfig(name)
    if not writefile then return false, "writefile unavailable" end
    local window = self.CurrentWindow
    local payload = {
        flags = self.Flags,
        toggleKey = self.ToggleKey.Name,
        isOpen = self.IsOpen,
        theme = self:SerializeTheme(),
        window = window and {
            position = {
                window.Main.Position.X.Scale,
                window.Main.Position.X.Offset,
                window.Main.Position.Y.Scale,
                window.Main.Position.Y.Offset,
            },
            size = {
                window.Main.Size.X.Scale,
                window.Main.Size.X.Offset,
                window.Main.Size.Y.Scale,
                window.Main.Size.Y.Offset,
            },
            minimized = window.Minimized,
        } or nil
    }

    writefile(self:GetConfigPath(name), HttpService:JSONEncode(payload))
    return true
end

function Library:LoadConfig(name)
    if not readfile then return false, "readfile unavailable" end
    local path = self:GetConfigPath(name)
    if not isfile or not isfile(path) then
        return false, "config missing"
    end

    local ok, decoded = pcall(function()
        return HttpService:JSONDecode(readfile(path))
    end)

    if not ok then
        return false, "invalid config"
    end

    self.Flags = decoded.flags or self.Flags
    self.IsOpen = decoded.isOpen ~= false

    if decoded.toggleKey and Enum.KeyCode[decoded.toggleKey] then
        self.ToggleKey = Enum.KeyCode[decoded.toggleKey]
    end

    self:ApplySerializedTheme(decoded.theme)

    local window = self.CurrentWindow
    if window and decoded.window then
        local p = decoded.window.position
        local s = decoded.window.size
        if p then
            window.Main.Position = UDim2.new(p[1], p[2], p[3], p[4])
        end
        if s then
            window.Main.Size = UDim2.new(s[1], s[2], s[3], s[4])
        end
        if decoded.window.minimized ~= nil then
            window:SetMinimized(decoded.window.minimized)
        end
        window:SetOpen(self.IsOpen)
    end

    return true
end

function Library:SetToggleKey(key)
    self.ToggleKey = key
end

function Library:BindGlobalToggle()
    table.insert(self.Connections, UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.KeyCode == self.ToggleKey and self.CurrentWindow then
            self.CurrentWindow:SetOpen(not self.IsOpen)
        end
    end))
end


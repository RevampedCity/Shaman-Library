local function tween(obj, time, props, style, direction)
    local t = TweenService:Create(
        obj,
        TweenInfo.new(time or 0.14, style or Enum.EasingStyle.Quad, direction or Enum.EasingDirection.Out),
        props
    )
    t:Play()
    return t
end

local function create(class, props)
    local instance = Instance.new(class)
    for k, v in pairs(props or {}) do
        instance[k] = v
    end
    return instance
end

local function corner(parent, radius)
    create("UICorner", {
        CornerRadius = UDim.new(0, radius or 6),
        Parent = parent
    })
end

local function stroke(parent, color, thickness, transparency)
    return create("UIStroke", {
        Color = color or Library.Theme.Stroke,
        Thickness = thickness or 1,
        Transparency = transparency or 0,
        Parent = parent
    })
end

local function padding(parent, left, right, top, bottom)
    create("UIPadding", {
        PaddingLeft = UDim.new(0, left or 0),
        PaddingRight = UDim.new(0, right or 0),
        PaddingTop = UDim.new(0, top or 0),
        PaddingBottom = UDim.new(0, bottom or 0),
        Parent = parent
    })
end

local function list(parent, sort, pad)
    return create("UIListLayout", {
        SortOrder = sort or Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, pad or 0),
        Parent = parent
    })
end

function Library:InitTooltip()
    if self.TooltipGui and self.TooltipGui.Parent then
        return
    end

    local gui = create("ScreenGui", {
        Name = "ShamanTooltips",
        ResetOnSpawn = false,
        ZIndexBehavior = Enum.ZIndexBehavior.Sibling,
        Parent = CoreGui,
    })

    local frame = create("Frame", {
        Visible = false,
        BackgroundColor3 = self.Theme.Surface2,
        BorderSizePixel = 0,
        Size = UDim2.fromOffset(120, 18),
        Parent = gui,
        ZIndex = 50,
    })
    corner(frame, 5)
    stroke(frame, self.Theme.Stroke, 1)

    local label = create("TextLabel", {
        BackgroundTransparency = 1,
        Size = UDim2.new(1, -8, 1, 0),
        Position = UDim2.new(0, 4, 0, 0),
        Font = Enum.Font.Gotham,
        TextSize = 9,
        TextColor3 = self.Theme.Text,
        TextXAlignment = Enum.TextXAlignment.Left,
        Parent = frame,
        ZIndex = 51,
    })

    self.TooltipGui = gui
    self.Tooltip = {Frame = frame, Label = label}
end

function Library:AddTooltip(object, text)
    if not text or text == "" then return end
    self:InitTooltip()

    local hover = false
    local function update()
        local pos = UserInputService:GetMouseLocation()
        local bounds = self.Tooltip.Label.TextBounds
        self.Tooltip.Frame.Size = UDim2.fromOffset(bounds.X + 10, 18)
        self.Tooltip.Frame.Position = UDim2.fromOffset(pos.X + 12, pos.Y - 6)
    end

    object.MouseEnter:Connect(function()
        hover = true
        self.Tooltip.Label.Text = text
        update()
        task.delay(0.25, function()
            if hover then
                self.Tooltip.Frame.Visible = true
            end
        end)
    end)

    object.MouseLeave:Connect(function()
        hover = false
        self.Tooltip.Frame.Visible = false
    end)

    if object:IsA("GuiObject") then
        object.MouseMoved:Connect(update)
    end
end

function Library:RegisterFlag(flag, control)
    if not flag then return end
    self.Registry[flag] = control
end

function Library:ApplyFlagToControl(flag, value)
    local control = self.Registry[flag]
    if control and control.Set then
        control:Set(value, true)
    end
end

function Library:ApplyAllFlags()
    for flag, value in pairs(self.Flags) do
        self:ApplyFlagToControl(flag, value)
    end
end

function Library:GetConfigPath(name)
    return string.format("%s/%s.json", self.ConfigFolder, name or self.ConfigName)
end

function Library:SerializeTheme()
    local data = {}
    for k, v in pairs(self.Theme) do
        if typeof(v) == "Color3" then
            data[k] = {v.R, v.G, v.B}
        end
    end
    return data
end

function Library:ApplySerializedTheme(theme)
    if not theme then return end
    for k, v in pairs(theme) do
        if type(v) == "table" and #v == 3 then
            self.Theme[k] = Color3.new(v[1], v[2], v[3])
        end
    end
end

function Library:SaveConfig(name)
    if not writefile then
        return false, "writefile unavailable"
    end

    local window = self.CurrentWindow
    local payload = {
        flags = self.Flags,
        toggleKey = self.ToggleKey.Name,
        isOpen = self.IsOpen,
        theme = self:SerializeTheme(),
        window = window and {
            position = {
                window.Main.Position.X.Scale,
                window.Main.Position.X.Offset,
                window.Main.Position.Y.Scale,
                window.Main.Position.Y.Offset,
            },
            size = {
                window.Main.Size.X.Scale,
                window.Main.Size.X.Offset,
                window.Main.Size.Y.Scale,
                window.Main.Size.Y.Offset,
            },
            minimized = window.Minimized,
        } or nil
    }

    local ok, err = pcall(function()
        writefile(self:GetConfigPath(name), HttpService:JSONEncode(payload))
    end)

    if not ok then
        return false, err
    end

    return true
end

function Library:LoadConfig(name)
    if not readfile then
        return false, "readfile unavailable"
    end

    local path = self:GetConfigPath(name)
    if not isfile(path) then
        return false, "config missing"
    end

    local ok, decoded = pcall(function()
        return HttpService:JSONDecode(readfile(path))
    end)

    if not ok then
        return false, "invalid config"
    end

    self.Flags = decoded.flags or self.Flags
    self.IsOpen = decoded.isOpen ~= false

    if decoded.toggleKey and Enum.KeyCode[decoded.toggleKey] then
        self.ToggleKey = Enum.KeyCode[decoded.toggleKey]
    end

    self:ApplySerializedTheme(decoded.theme)

    local window = self.CurrentWindow
    if window and decoded.window then
        local p = decoded.window.position
        local s = decoded.window.size
        if p then
            window.Main.Position = UDim2.new(p[1], p[2], p[3], p[4])
        end
        if s then
            window.Main.Size = UDim2.new(s[1], s[2], s[3], s[4])
            window.StoredSize = window.Main.Size
        end
        if decoded.window.minimized ~= nil then
            window:SetMinimized(decoded.window.minimized)
        end
        window:SetOpen(self.IsOpen)
        if window.ApplyTheme then
            window:ApplyTheme()
        end
    end

    self:ApplyAllFlags()
    return true
end

function Library:SetToggleKey(key)
    self.ToggleKey = key
end

function Library:BindGlobalToggle()
    table.insert(self.Connections, UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.KeyCode == self.ToggleKey and self.CurrentWindow then
            self.CurrentWindow:SetOpen(not self.IsOpen)
        end
    end))
end


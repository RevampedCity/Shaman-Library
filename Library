            if gp then return end
            if input.UserInputType == Enum.UserInputType.Keyboard and not Library.Blacklist[input.KeyCode] then
                Library:SetToggleKey(input.KeyCode)
                keyText.Text = "Toggle: " .. Library.ToggleKey.Name
                keybindButton.Text = "Toggle Key (" .. Library.ToggleKey.Name .. ")"
                capture:Disconnect()
            end
        end)

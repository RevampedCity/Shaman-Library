    function window:ClampToScreen()
        local camera = workspace.CurrentCamera
        if not camera then return end
        local viewport = camera.ViewportSize
        local abs = main.AbsoluteSize
        local pos = main.AbsolutePosition
        local x = math.clamp(pos.X + abs.X / 2, abs.X / 2 + 6, viewport.X - abs.X / 2 - 6)
        local y = math.clamp(pos.Y + abs.Y / 2, abs.Y / 2 + 6, viewport.Y - abs.Y / 2 - 6)
        main.Position = UDim2.fromOffset(x, y)
    end

    function window:SetMinimized(state)
        window.Minimized = state
        if state then
            window.StoredSize = main.Size
            resizeGrip.Visible = false
            body.Visible = true
            tween(body, 0.14, {Position = UDim2.fromOffset(0, -8)})
            task.delay(0.12, function()
                if window.Minimized then body.Visible = false end
            end)
            tween(main, 0.18, {Size = UDim2.new(main.Size.X.Scale, main.Size.X.Offset, 0, 34)})
        else
            body.Visible = true
            body.Position = UDim2.fromOffset(0, -8)
            resizeGrip.Visible = true
            tween(main, 0.18, {Size = window.StoredSize})
            tween(body, 0.16, {Position = UDim2.fromOffset(0, 34)})
            task.delay(0.2, function()
                window:ClampToScreen()
            end)
        end
    end

